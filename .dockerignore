# VCS / tooling
.git
.gitea
.gitignore
.dockerignore

# Local artefacts
/tmp
/bin
/dist

# Node deps are installed fresh by `npm ci` in the web-builder stage.
# Never ship a host node_modules into the build context: a stale local
# tree would otherwise overlay the freshly-resolved deps via `COPY web/`.
# Use `**/node_modules` — a bare `node_modules` only matches the
# build-context root, not the nested `web/node_modules` that the web
# build actually populates.
**/node_modules

# testdata runtime state
/testdata/vault/.gosidian
/testdata/vault/Lavoro
/testdata/vault/Studio

# Editor
.vscode
.idea
*.swp
*.swo
.DS_Store

# Claude / plan artifacts
.claude

# Codespaces demo (devcontainer config + demo vault) — not part of the
# image build context.
.devcontainer

# Deployment extras (not needed inside the build context when the
# Dockerfile is built from repo root)
deploy
